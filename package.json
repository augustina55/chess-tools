{
  "name": "chess-tools",
  "version": "1.0.0",
  "description": "Chess Tools — PDF to PGN extractor & Puzzle Generator",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n \"server,client\" -c \"green.bold,cyan.bold\" \"nodemon server.js\" \"vite\"",
    "dev:server": "nodemon server.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@libsql/client": "^0.17.3",
    "chess.js": "^1.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.42.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.1.0",
    "react-chessboard": "^5.10.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5"
  }
}
